# 复制为 .env 后填入真实值(.env 不会被提交)
# npm start / npm run dev 会通过 --env-file-if-exists=.env 自动加载

# 外部账号接口地址
DOUBAO_POOL_API_URL=
# 调用账号接口的 Bearer(真实凭据,勿写入 git)
DOUBAO_POOL_API_TOKEN=
# 接入鉴权 key(逗号分隔，客户端命中任一即放行;可用 node -e "console.log('sk-'+require('crypto').randomBytes(24).toString('hex'))" 生成)
DOUBAO_AUTH_KEYS=
